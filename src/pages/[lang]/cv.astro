---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteShell from "../../components/SiteShell.astro";
import CVDashboard from "../../components/CVDashboard.jsx";
import { ui } from "../../i18n/ui";
import { isLang } from "../../i18n/utils";

export async function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "es" } }, { params: { lang: "nl" } }];
}

const { lang } = Astro.params;
if (!lang || !isLang(lang)) throw new Error("Invalid lang");
const t = ui[lang];

// PDFs you already have in /public/assets/...
const downloads = {
  focused: "/assets/Focus-cv.pdf",
  
};
---

<BaseLayout lang={lang} title={`${t.nav.cv} — Pierina Lopez`}>
  <SiteShell active="cv" lang={lang}>
    <div class="max-w-6xl">
      <CVDashboard client:load lang={lang} t={t} downloads={downloads} />
    </div>
  </SiteShell>
</BaseLayout>