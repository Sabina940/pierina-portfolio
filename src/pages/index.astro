---
import { defaultLang } from "../i18n/config";

// Optional: if you *always* want / -> /en (static redirect):
return Astro.redirect(`/${defaultLang}`);

// Better: let Netlify handle redirects and keep this page minimal.
---

<script is:inline>
  const saved = localStorage.getItem("lang");
  const lang = (saved === "en" || saved === "es" || saved === "nl") ? saved : "{defaultLang}";
  window.location.replace("/" + lang + "/");
</script>

<noscript>
  <meta http-equiv="refresh" content="0; url=/{defaultLang}/" />
</noscript>