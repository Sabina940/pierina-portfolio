---
import "../styles/global.css";

const {
  title = "Pierina Lopez",
  description = "Architect transitioning into Applied Computer Science — bridging AEC operations with AI/ML, computer vision, automation, and data visualization.",
} = Astro.props;
---

<!doctype html>
<html lang={Astro.props.lang ?? "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <link rel="mask-icon" href="/favicon/safari-pinned-tab.svg" color="#0f4b44" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <meta name="msapplication-TileColor" content="#0f4b44" />
    <meta name="msapplication-config" content="/favicon/browserconfig.xml" />
    <meta name="theme-color" content="#0f4b44" />
  </head>

  <body class="min-h-screen bg-neutral-950 text-neutral-50 antialiased">
    <slot />
  </body>
</html>