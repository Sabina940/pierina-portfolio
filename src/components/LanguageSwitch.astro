---
import { languageLabels, languages } from "../i18n/config";

const { lang = "en" } = Astro.props;

const currentPath = Astro.url.pathname;
// replace first segment if it's a language
function hrefFor(code: string) {
  const parts = currentPath.split("/").filter(Boolean);
  if (parts.length === 0) return `/${code}/`;
  if (["en", "es", "nl"].includes(parts[0])) parts[0] = code;
  else parts.unshift(code);
  return "/" + parts.join("/") + (currentPath.endsWith("/") ? "/" : "");
}
---

<div class="mt-6 rounded-2xl border border-white/10 bg-white/5 p-4">
  <div class="text-xs font-semibold text-white/80 mb-3">Language</div>
  <div class="flex gap-2">
    {languages.map((code) => (
      <a
        href={hrefFor(code)}
        class:list={[
          "rounded-xl px-3 py-2 text-xs font-semibold border transition",
          code === lang
            ? "bg-white/10 border-white/20 text-white"
            : "bg-white/5 border-white/10 text-white/70 hover:text-white hover:bg-white/10",
        ]}
      >
        {languageLabels[code]}
      </a>
    ))}
  </div>
</div>