---
const {
  title,
  text,
  imgSrc,
  videoSrc,
} = Astro.props;

const isVideo = !!videoSrc;
---

<button
  type="button"
  class="world-tile group relative w-full overflow-hidden rounded-3xl border border-white/10 bg-white/5 text-left transition hover:bg-white/10"
  aria-pressed="false"
>
  <div class="relative aspect-[4/3]">
    <!-- FRONT -->
    <!-- FRONT -->
        {isVideo && (
        <video
            class="front-media absolute inset-0 h-full w-full object-cover"
            src={videoSrc}
            muted
            loop
            playsinline
            autoplay
            preload="metadata"
        ></video>
        )}

        {!isVideo && (
        <img
            class="front-media absolute inset-0 h-full w-full object-cover"
            src={imgSrc}
            alt={title}
            loading="lazy"
        />
        )}

    <div class="front-overlay absolute inset-0 bg-gradient-to-t from-black/70 via-black/15 to-transparent"></div>

    <div class="front-caption absolute bottom-0 left-0 right-0 p-4">
      <div class="text-sm font-semibold text-white">{title}</div>
      <div class="mt-1 text-xs text-white/70">Tap to read</div>
    </div>

    <!-- BACK -->
    <div class="back-panel absolute inset-0 grid place-items-center p-5 opacity-0" aria-hidden="true">
      <div>
        <div class="text-sm font-semibold text-white">{title}</div>
        <p class="mt-2 text-sm leading-relaxed text-white/75">{text}</p>
        <div class="mt-3 text-xs text-white/60">Tap again to close</div>
      </div>
    </div>
  </div>
</button>

<style>
  .world-tile[aria-pressed="true"] .back-panel { opacity: 1; }
  .world-tile[aria-pressed="true"] .front-media,
  .world-tile[aria-pressed="true"] .front-overlay,
  .world-tile[aria-pressed="true"] .front-caption { opacity: 0; pointer-events: none; }

  .back-panel {
    background: rgba(10,10,10,0.75);
    backdrop-filter: blur(12px);
    transition: opacity 200ms ease;
  }
  .front-media { 
    pointer-events: none; 
    transition: opacity 200ms ease; }
</style>

<script is:inline>
  // Attach once (even if multiple tiles/components include this script)
  if (!window.__worldTileBound) {
    window.__worldTileBound = true;

    document.addEventListener("click", (e) => {
      const tile = e.target.closest(".world-tile");
      if (!tile) return;

      const isPressed = tile.getAttribute("aria-pressed") === "true";
      tile.setAttribute("aria-pressed", isPressed ? "false" : "true");

      const vid = tile.querySelector("video");
      if (vid) {
        if (!isPressed) vid.play().catch(() => {});
        else vid.pause();
      }
    });
  }
</script>